<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JUMBO QR Generator & Matching System</title>
    <!-- CSS and Fonts -->
    <link rel="stylesheet" href="css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <!-- QRCode.js (CDN) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
</head>
<body>
    <div class="app-container no-print">
        <!-- Sidebar Navigation -->
        <nav class="sidebar">
            <div class="logo">
                <h2>JUMBO System</h2>
                <p>QR Gen & Traceability</p>
            </div>
            <ul class="nav-menu">
                <li class="active" data-target="tab-qr"><i class="icon">🖨️</i> พิมพ์สติ๊กเกอร์ QR</li>
                <li data-target="tab-match-main"><i class="icon">⚙️</i> ประกอบ BBAS MAIN</li>
                <li data-target="tab-match-rsu"><i class="icon">🔌</i> ประกอบ BBAS RSU</li>
                <li data-target="tab-packing"><i class="icon">📦</i> Packing</li>
                <li data-target="tab-history"><i class="icon">📊</i> ประวัติข้อมูล (Export)</li>
            </ul>
        </nav>

        <!-- Main Content -->
        <main class="content-area">
            
            <!-- TAB 1: QR Generator -->
            <section id="tab-qr" class="tab-pane active">
                <div class="header">
                    <h1>QR Code Print Studio</h1>
                    <p>สร้างหมายเลขซีเรียลและพิมพ์สติ๊กเกอร์ 5x5mm / 20x20mm</p>
                </div>
                
                <div class="card">
                    <form id="qr-form" class="form-grid">
                        <div class="form-group">
                            <label>เลือกรายการ Part (Part Number)</label>
                            <select id="part-select" required>
                                <optgroup label="PCBA (5x5 mm)">
                                    <option value="1E4D25234000">1E4D25234000 - PCBA MAIN (60 ดวง)</option>
                                    <option value="1E4D25234001">1E4D25234001 - PCBA IO (120 ดวง)</option>
                                    <option value="1E4D25234002">1E4D25234002 - PCBA RS485 (180 ดวง)</option>
                                    <option value="1E4D25234003">1E4D25234003 - PCBA RSU (60 ดวง)</option>
                                </optgroup>
                                <optgroup label="BBAS (20x20 mm - พิมพ์ 2 ชุด/หมายเลข)">
                                    <option value="1E6D25234000">1E6D25234000 - BBAS MAIN (60 เลข/120 ดวง)</option>
                                    <option value="1E6D25234001">1E6D25234001 - BBAS RSU (60 เลข/120 ดวง)</option>
                                </optgroup>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>เลขเริ่มต้น (Start Serial)</label>
                            <input type="number" id="serial-start" value="1" min="1" required>
                        </div>
                        <div class="form-group">
                            <label>จำนวนที่ต้องการสร้าง (ดวง/หมายเลข)</label>
                            <input type="number" id="serial-qty" value="60" min="1" required>
                        </div>
                        <div class="form-group btn-group align-bottom">
                            <button type="submit" class="btn btn-primary">สร้าง QR Code</button>
                            <button type="button" id="btn-print" class="btn btn-success" disabled>พิมพ์ (Print)</button>
                        </div>
                    </form>
                </div>

                <div class="preview-area">
                    <h3>ผลลัพธ์การสร้าง (<span id="preview-count">0</span> รายการ)</h3>
                    <div id="qr-preview-container" class="preview-grid">
                        <!-- QR Codes preview will be appended here -->
                    </div>
                </div>
            </section>

            <!-- TAB 2: BBAS MAIN Matching -->
            <section id="tab-match-main" class="tab-pane">
                <div class="header">
                    <h1>ประกอบ BBAS MAIN</h1>
                    <p>สแกนจับคู่ 1 BBAS MAIN = (1 PCBA MAIN, 2 PCBA IO, 3 PCBA RS485)</p>
                </div>
                <div class="card scanning-card">
                    <form id="match-main-form">
                        <div class="scan-step primary-scan">
                            <label>1. สแกนเลข BBAS MAIN (1E6D25234000)</label>
                            <input type="text" id="scan-bb-main" class="scan-input" placeholder="คลิกที่นี่แล้วสแกน..." required autocomplete="off">
                            <span class="status-icon"></span>
                        </div>
                        <div class="scan-grid">
                            <div class="scan-step">
                                <label>2. สแกน PCBA MAIN (1E4D25234000)</label>
                                <input type="text" id="scan-pc-main-1" class="scan-input" placeholder="สแกน PCBA MAIN" disabled required autocomplete="off">
                                <span class="status-icon"></span>
                            </div>
                            <div class="scan-step">
                                <label>3. สแกน PCBA IO #1 (1E4D25234001)</label>
                                <input type="text" id="scan-pc-io-1" class="scan-input" placeholder="สแกน PCBA IO 1" disabled required autocomplete="off">
                                <span class="status-icon"></span>
                            </div>
                            <div class="scan-step">
                                <label>4. สแกน PCBA IO #2 (1E4D25234001)</label>
                                <input type="text" id="scan-pc-io-2" class="scan-input" placeholder="สแกน PCBA IO 2" disabled required autocomplete="off">
                                <span class="status-icon"></span>
                            </div>
                            <div class="scan-step">
                                <label>5. สแกน PCBA RS485 #1 (1E4D25234002)</label>
                                <input type="text" id="scan-pc-rs-1" class="scan-input" placeholder="สแกน RS485 1" disabled required autocomplete="off">
                                <span class="status-icon"></span>
                            </div>
                            <div class="scan-step">
                                <label>6. สแกน PCBA RS485 #2 (1E4D25234002)</label>
                                <input type="text" id="scan-pc-rs-2" class="scan-input" placeholder="สแกน RS485 2" disabled required autocomplete="off">
                                <span class="status-icon"></span>
                            </div>
                            <div class="scan-step">
                                <label>7. สแกน PCBA RS485 #3 (1E4D25234002)</label>
                                <input type="text" id="scan-pc-rs-3" class="scan-input" placeholder="สแกน RS485 3" disabled required autocomplete="off">
                                <span class="status-icon"></span>
                            </div>
                        </div>
                        <div class="form-actions">
                            <button type="button" id="btn-reset-main" class="btn btn-secondary">เริ่มใหม่ (Reset)</button>
                            <button type="submit" id="btn-save-main" class="btn btn-primary" disabled>บันทึกการจับคู่</button>
                        </div>
                    </form>
                </div>
            </section>

            <!-- TAB 3: BBAS RSU Matching -->
            <section id="tab-match-rsu" class="tab-pane">
                <div class="header">
                    <h1>ประกอบ BBAS RSU</h1>
                    <p>สแกนจับคู่ 1 BBAS RSU = (1 PCBA RSU)</p>
                </div>
                <div class="card scanning-card">
                    <form id="match-rsu-form">
                        <div class="scan-step primary-scan">
                            <label>1. สแกนเลข BBAS RSU (1E6D25234001)</label>
                            <input type="text" id="scan-bb-rsu" class="scan-input" placeholder="คลิกที่นี่แล้วสแกน..." required autocomplete="off">
                            <span class="status-icon"></span>
                        </div>
                        <div class="scan-step primary-scan mt-4">
                            <label>2. สแกน PCBA RSU (1E4D25234003)</label>
                            <input type="text" id="scan-pc-rsu" class="scan-input" placeholder="สแกน PCBA RSU" disabled required autocomplete="off">
                            <span class="status-icon"></span>
                        </div>
                        <div class="form-actions mt-4">
                            <button type="button" id="btn-reset-rsu" class="btn btn-secondary">เริ่มใหม่ (Reset)</button>
                            <button type="submit" id="btn-save-rsu" class="btn btn-primary" disabled>บันทึกการจับคู่</button>
                        </div>
                    </form>
                </div>
            </section>

            <!-- TAB 4: Packing -->
            <section id="tab-packing" class="tab-pane">
                <div class="header flex-between">
                    <div>
                        <h1>Packing</h1>
                        <p>สแกน BBAS ใส่กล่อง และปิดกล่องก่อนส่ง</p>
                    </div>
                    <div>
                        <button id="btn-new-box" class="btn btn-primary">+ สร้าง Box ใหม่</button>
                    </div>
                </div>
                <div id="boxes-container" class="card" style="min-height:120px">
                    <p style="color:#94a3b8;text-align:center;padding:2rem">กำลังโหลด...</p>
                </div>
            </section>

            <!-- TAB 5: History & Export -->
            <section id="tab-history" class="tab-pane">
                <div class="header flex-between">
                    <div>
                        <h1>ประวัติการจับคู่ชิ้นงาน</h1>
                        <p>ข้อมูลถูกเก็บไว้ใน Database</p>
                    </div>
                    <div>
                        <button id="btn-export-csv" class="btn btn-success">⬇️ ดาวน์โหลด Excel (CSV)</button>
                        <button id="btn-clear-history" class="btn btn-danger">🗑️ ล้างข้อมูลทั้งหมด</button>
                    </div>
                </div>
                <div class="card overflow-auto">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>เวลา (Date/Time)</th>
                                <th>ประเภทงาน (Assembly)</th>
                                <th>BBAS Serial</th>
                                <th>รายการชิ้นส่วน (Components)</th>
                                <th>จัดการ</th>
                            </tr>
                        </thead>
                        <tbody id="history-table-body">
                            <!-- Rows will be populated here -->
                        </tbody>
                    </table>
                </div>
            </section>

        </main>
    </div>

    <!-- Print Container (Hidden from Screen UI, visible only in Print mode) -->
    <div id="print-container" class="print-only"></div>

    <!-- Login Overlay -->
    <div id="login-overlay" style="display:none;position:fixed;inset:0;background:rgba(10,14,26,.92);z-index:9999;align-items:center;justify-content:center;">
      <div style="background:#1e293b;border:1px solid #334155;border-radius:16px;padding:2.5rem 2rem;width:100%;max-width:360px;box-shadow:0 20px 60px rgba(0,0,0,.6);">
        <h2 style="color:#f1f5f9;margin:0 0 .25rem;font-size:1.4rem;text-align:center;">JUMBO System</h2>
        <p style="color:#94a3b8;text-align:center;margin:0 0 1.75rem;font-size:.9rem;">กรุณาเข้าสู่ระบบเพื่อใช้งาน</p>
        <form id="login-form" autocomplete="off">
          <div style="margin-bottom:1rem;">
            <label style="display:block;color:#94a3b8;font-size:.85rem;margin-bottom:.4rem;">ชื่อผู้ใช้</label>
            <input id="login-username" type="text" autocomplete="username" style="width:100%;padding:.65rem .9rem;background:#0f172a;border:1px solid #334155;border-radius:8px;color:#f1f5f9;font-size:1rem;box-sizing:border-box;" placeholder="username">
          </div>
          <div style="margin-bottom:1.5rem;">
            <label style="display:block;color:#94a3b8;font-size:.85rem;margin-bottom:.4rem;">รหัสผ่าน</label>
            <input id="login-password" type="password" autocomplete="current-password" style="width:100%;padding:.65rem .9rem;background:#0f172a;border:1px solid #334155;border-radius:8px;color:#f1f5f9;font-size:1rem;box-sizing:border-box;" placeholder="password">
          </div>
          <button type="submit" style="width:100%;padding:.75rem;background:linear-gradient(135deg,#6366f1,#8b5cf6);border:none;border-radius:8px;color:#fff;font-size:1rem;font-weight:600;cursor:pointer;">เข้าสู่ระบบ</button>
        </form>
      </div>
    </div>

    <script src="js/app.js"></script>
</body>
</html>
