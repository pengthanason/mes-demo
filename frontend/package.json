  "type": "module",
  "scripts": {
    "dev": "node -e \"require(require('node:path').resolve(process.env.INIT_CWD || process.cwd(), '../scripts/run-project-bin.cjs'))('./node_modules/vite/bin/vite.js')\"",
    "build": "node -e \"require(require('node:path').resolve(process.env.INIT_CWD || process.cwd(), '../scripts/run-project-bin.cjs'))('../scripts/build-frontend.mjs')\"",
    "preview": "node -e \"require(require('node:path').resolve(process.env.INIT_CWD || process.cwd(), '../scripts/run-project-bin.cjs'))('./node_modules/vite/bin/vite.js', ['preview'])\"",
    "typecheck": "node -e \"require(require('node:path').resolve(process.env.INIT_CWD || process.cwd(), '../scripts/run-project-bin.cjs'))('./node_modules/typescript/bin/tsc', ['--noEmit'])\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "@tanstack/react-query": "^5.100.1",
