MES_PUBLIC_PORT=5100
MES_APP_VERSION=0.1.0-station2
MES_ENV=dev
MES_READY_STRICT=false
MES_CORS_ORIGINS=http://127.0.0.1:5100,http://localhost:5100
MES_AUTH_MODE=hybrid
MES_JWT_ISSUER=syntech-mes-backbone
MES_JWT_SECRET=
MES_RATE_LIMIT_ENABLED=true
MES_RATE_LIMIT_WINDOW_MS=60000
MES_RATE_LIMIT_MAX_REQUESTS=100
MES_JWT_ACCESS_TTL_SEC=900
MES_JWT_REFRESH_TTL_SEC=604800
MES_MAX_CONCURRENT_SESSIONS=3
MES_SESSION_INACTIVITY_SEC=1800
MES_PROD_DB_HOST=
MES_PROD_DB_NAME=

# DB shared from syntech_wms postgres container (external port)
MES_DB_HOST=host.docker.internal
MES_DB_PORT=15432
MES_DB_NAME=productiondb
MES_DB_USER=syntechdb
MES_DB_PASSWORD=change_me
MES_DB_SSLMODE=prefer
MES_DB_CONNECT_TIMEOUT=5000
